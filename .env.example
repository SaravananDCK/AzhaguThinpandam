# Copy to .env and fill in. See DEPLOYMENT.md for production values.
DATABASE_URL="file:./dev.db"

# Production only: your domain, used by Caddy for automatic HTTPS
DOMAIN="localhost"

# Generate with: openssl rand -base64 32
AUTH_SECRET=""
AUTH_TRUST_HOST="true"

# Razorpay keys (https://dashboard.razorpay.com → Settings → API Keys)
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
# Webhook secret you set when creating the webhook in the Razorpay dashboard
RAZORPAY_WEBHOOK_SECRET=""
# Same as RAZORPAY_KEY_ID (exposed to the browser for Checkout.js)
NEXT_PUBLIC_RAZORPAY_KEY_ID=""

# Customer login OTPs go out over WhatsApp. Configure ONE of the two drivers
# below (Twilio wins if both are set). Leave both empty in development: the
# login page shows the code on screen instead. In production one is REQUIRED
# (customer login returns 503 without it).

# Driver 1: Twilio WhatsApp API (quickest; ~₹0.55/login in India)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
# e.g. "whatsapp:+14155238886" (sandbox) or your approved WhatsApp sender
TWILIO_WHATSAPP_FROM=""
# Content SID (HX…) of your approved auth template; leave empty for sandbox
TWILIO_CONTENT_SID=""

# Driver 2: Meta Cloud API directly (cheapest; ~₹0.13/login)
# Setup: https://developers.facebook.com → WhatsApp → API Setup
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""
# Name/language of your approved "authentication" template
WHATSAPP_OTP_TEMPLATE="login_otp"
WHATSAPP_OTP_LANGUAGE="en"

# SMTP for order emails (e.g. Hostinger email: smtp.hostinger.com:587)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="AzhaguThinpandam <orders@yourdomain.com>"
# Where new-order notifications are sent
ADMIN_EMAIL=""

# Public URL of the site (no trailing slash)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# DevExtreme license key (admin accounting UI) — from your DevExpress account.
# Without it, DevExtreme shows a trial watermark in the admin panel.
NEXT_PUBLIC_DEVEXTREME_KEY=""

# Where admin-uploaded product images are stored (a Docker volume in production)
UPLOADS_DIR="./uploads"
